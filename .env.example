# CIM Analyst — Environment Variables
# Copy to .env and fill in values

# Census API key for demographic enrichment (optional)
CENSUS_API_KEY=

# Data paths (defaults work for local dev — set these for Docker)
# COMP_DB_PATH=/data/cim_comps.db
# CIM_DEALS_DIR=/data/deals
# CIM_OVERRIDES_DIR=/data/overrides

# Underwriting template path (optional — defaults to template_uw.xlsm in project root)
# UW_TEMPLATE_PATH=/app/template_uw.xlsm

# Fund structure defaults for underwriting template (optional)
# GP_NAME=GP
# GP_EQUITY_SHARE=0.06
# GP_AM_FEE_RATE=0.01
# GP_PROMOTE_PCT=0.20
